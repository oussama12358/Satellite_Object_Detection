################################################################################
# SatDet Environment Configuration
# 
# Copy this file to .env and fill in the appropriate values for your environment.
# Settings are organized by functional area.
################################################################################

# ═══════════════════════════════════════════════════════════════════════════
# MODEL & INFERENCE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Path to model weights file (trained checkpoint)
# Examples: "models/weights/best.pt", "models/weights/last.pt", "yolov8s.pt"
MODEL_WEIGHTS=models/weights/best.pt

# Model version identifier (for tracking and documentation)
MODEL_VERSION=yolov8s-satdet-v1

# Compute device for inference
# Options: "cpu", "cuda:0", "cuda:1", etc. (check GPU availability with `nvidia-smi`)
# Development: "cpu" (slower but portable)
# Production: "cuda:0" (if GPU available, ~25x faster)
DEVICE=cuda:0

# Confidence threshold for detections (0.0-1.0)
# Lower values = more detections (higher recall, lower precision)
# Typical range: 0.15-0.35 depending on false positive tolerance
CONF_THRESHOLD=0.25

# IoU threshold for Non-Maximum Suppression (0.0-1.0)
# Controls overlap tolerance when merging overlapping detections
# Typical range: 0.40-0.50
IOU_THRESHOLD=0.45

# Maximum input image size in MB (prevents OOM on very large images)
# Increase if available GPU VRAM > 8GB, decrease for limited memory
MAX_IMAGE_MB=50

# ═══════════════════════════════════════════════════════════════════════════
# API CONFIGURATION (FastAPI Server)
# ═══════════════════════════════════════════════════════════════════════════

# API server host binding
# 0.0.0.0 = accessible from any network interface (production)
# 127.0.0.1 = localhost only (development)
API_HOST=0.0.0.0

# API server port
# Make sure port is not already in use (check with `lsof -i :8000`)
API_PORT=8000

# Number of Uvicorn worker processes
# Recommended: 1-2 * number of CPU cores
# For single GPU: 2-4 workers
API_WORKERS=2

# ═══════════════════════════════════════════════════════════════════════════
# EXPERIMENT TRACKING (MLflow)
# ═══════════════════════════════════════════════════════════════════════════

# MLflow tracking server URI
# Local setup: http://localhost:5000 (run `mlflow ui` separately)
# Remote: http://mlflow-server.example.com:5000
# Disabled: leave empty or set to "file:./mlruns" for local file storage
MLFLOW_TRACKING_URI=http://localhost:5000

# MLflow experiment name (groups related training runs)
MLFLOW_EXPERIMENT=satdet_yolov8s

# ═══════════════════════════════════════════════════════════════════════════
# DATASET & DATA PIPELINE
# ═══════════════════════════════════════════════════════════════════════════

# Path to raw DOTA dataset directory
# Contains: images/, annotations_train/, annotations_val/, annotations_test/
DOTA_DIR=data/raw/dota

# Base output directory for processed data
# Created by dataset preparation scripts
OUTPUT_DIR=data/processed

# Directory for train/val/test split indices
# Created by dataset_splitter.py
SPLITS_DIR=data/splits

# Tile size for image tiling pipeline (in pixels)
# Must be square; standard for YOLOv8: 640, 512, or 416
# Larger = more context but higher memory, smaller = more tiles but less context
TILE_SIZE=640

# Overlap ratio for tiled crops (0.0-1.0)
# 0.0 = no overlap (edge cases missed)
# 0.2 = 20% overlap (recommended, balances context and computation)
# 0.5 = 50% overlap (high computation, best for small objects)
OVERLAP=0.2

# DOTA dataset version
# Supported: "v1.0", "v1.5", "v2.0"
DOTA_VERSION=v1.5

# ═══════════════════════════════════════════════════════════════════════════
# LOGGING & DEBUGGING
# ═══════════════════════════════════════════════════════════════════════════

# Log level for application logging
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log output directory (for file-based logging)
# Leave empty to disable file logging
LOG_DIR=logs

# Enable detailed request/response logging in API
# Useful for debugging but verbose in production
DEBUG_API_LOGS=false
